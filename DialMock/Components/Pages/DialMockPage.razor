@page "/dialmock"
@inject DialRuleEngine RuleEngine
@inject DialEngine Engine

<PageTitle>Dial Mock</PageTitle>

<h1>Dial Mock</h1> 

<div class="dialmock-page">
    <div class="editor-card">
        <EditForm Model="_spec" FormName="DialPreviewForm">
            <DataAnnotationsValidator />
            <ValidationSummary />

            <div class="form-grid">
                <div class="field">
                    <label for="title">Title</label>
                    <InputText id="title" @bind-Value="_spec.Title" />
                </div>

                <div class="field">
                    <label for="unit">Unit</label>
                    <InputText id="unit" @bind-Value="_spec.Unit" />
                </div>

                <div class="field">
                    <label for="minValue">Min value</label>
                    <InputNumber id="minValue" @bind-Value="_spec.MinValue" />
                </div>

                <div class="field">
                    <label for="maxValue">Max value</label>
                    <InputNumber id="maxValue" @bind-Value="_spec.MaxValue" />
                </div>

                <div class="field">
                    <label for="previewValue">Preview value</label>
                    <InputNumber id="previewValue" @bind-Value="_spec.PreviewValue" />
                </div>

                <div class="field">
                    <label for="majorTickCount">Major ticks</label>
                    <InputNumber id="majorTickCount" @bind-Value="_spec.MajorTickCount" />
                </div>
            </div>

            <div class="actions">
                <button type="button" @onclick="HandlePreview">Render preview</button>
            </div>
        </EditForm>

        @if (_validation is not null && !_validation.IsValid)
        {
            <div class="validation-errors">
                <strong>Validation errors</strong>
                <ul>
                    @foreach (var error in _validation.Errors)
                    {
                        <li>@error</li>
                    }
                </ul>
            </div>
        }
    </div>

    @if (_renderData is not null && _drawing is not null)
    {
        <div class="preview-card">
            <svg viewBox="0 0 400 260" class="dial-preview" role="img" aria-label="Dial preview">
                @foreach (var arc in _drawing.Arcs)
                {
                    <path d="@SvgArcPath(arc)" class="dial-arc" />
                }

                @foreach (var line in _drawing.Lines)
                {
                    var cssClass = line == _drawing.Lines.Last() ? "dial-needle" : "dial-tick";

                    <line x1="@SvgX(line.Start.X)"
                        y1="@SvgY(line.Start.Y)"
                        x2="@SvgX(line.End.X)"
                        y2="@SvgY(line.End.Y)"
                        class="@cssClass" />
                }

                <circle cx="200" cy="200" r="8" class="dial-center" />

                @foreach (var text in _drawing.Texts)
                {
                    @SvgText(
                        SvgX(text.Position.X),
                        SvgY(text.Position.Y),
                        text.Content,
                        "dial-label")
                }

                @SvgText(200, 30, _renderData.Title, "dial-title")
                @SvgText(200, 224, _renderData.Unit, "dial-unit")
            </svg>
        </div>
    }
</div>

@code {
    private DialSpec _spec = new();
    private DialRenderData? _renderData;
    private ValidationResult? _validation;
    private DialDrawing? _drawing;

    protected override void OnInitialized()
    {
        HandlePreview();
    }

    private void HandlePreview()
    {
        _validation = RuleEngine.Validate(_spec);

        if (!_validation.IsValid)
        {
            _renderData = null;
            _drawing = null;
            return;
        }

        _renderData = RuleEngine.BuildRenderData(_spec);
        _drawing = Engine.BuildDrawing(_spec);
    }

    private static double SvgX(double x) => 200 + x;

    private static double SvgY(double y) => 200 - y;

    private static string SvgArcPath(Arc2 arc)
    {
        var start = Polar(arc.Center, arc.Radius, arc.StartAngleDeg);
        var end = Polar(arc.Center, arc.Radius, arc.StartAngleDeg + arc.SweepAngleDeg);

        var largeArcFlag = Math.Abs(arc.SweepAngleDeg) > 180 ? 1 : 0;
        var sweepFlag = arc.SweepAngleDeg >= 0 ? 0 : 1;

        return $"M {SvgX(start.X):0.##} {SvgY(start.Y):0.##} " +
               $"A {arc.Radius:0.##} {arc.Radius:0.##} 0 {largeArcFlag} {sweepFlag} {SvgX(end.X):0.##} {SvgY(end.Y):0.##}";
    }

    private static Point2 Polar(Point2 center, double radius, double angleDegrees)
    {
        var radians = Math.PI * angleDegrees / 180.0;

        return new Point2(
            center.X + radius * Math.Cos(radians),
            center.Y + radius * Math.Sin(radians)
        );
    }

    private static MarkupString SvgText(double x, double y, string content, string cssClass)
    {
        var encoded = System.Net.WebUtility.HtmlEncode(content);

        return new MarkupString(
            $"""<text x="{x:0.##}" y="{y:0.##}" class="{cssClass}" text-anchor="middle">{encoded}</text>"""
        );
    }
}